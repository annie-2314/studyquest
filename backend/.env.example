# --- Phase 1 (required to run) ---
DATABASE_URL=sqlite:///./studyquest.db
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_ORIGIN=http://localhost:3000

# --- Phase 2+: LLM via OpenRouter (OpenAI-compatible) ---
# Paste your key here. WITHOUT it the tutor runs in a deterministic mock mode.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# FAST = cheap tier for high-volume text (chat, quizzes, summaries, flashcards).
# SMART = used only where it matters (image solver needs vision; harder reasoning).
OPENROUTER_MODEL_FAST=deepseek/deepseek-chat
OPENROUTER_MODEL_SMART=openai/gpt-4o-mini

# --- YouTube auth (optional) — fixes "Please sign in" anti-bot blocking ---
# Use your logged-in browser cookies for yt-dlp + transcripts. Be signed into
# YouTube in that browser. Values: edge | chrome | firefox
# YTDLP_COOKIES_FROM_BROWSER=edge
# Or use an exported Netscape cookies.txt instead:
# YOUTUBE_COOKIES_FILE=C:/path/to/cookies.txt

# --- Phase 10: LangSmith tracing (optional) ---
# LANGCHAIN_API_KEY=
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=studyquest-ai

# --- Local LLM via Ollama (no API key) — set LLM_BACKEND=ollama to use it ---
# LLM_BACKEND=openrouter            # openrouter | ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL_FAST=llama3.1
# OLLAMA_MODEL_SMART=llama3.1

# --- Grounded RAG (free, local embeddings) ---
# EMBEDDINGS_MOCK=1                 # deterministic hash embeddings (tests/offline; no model download)
# ENABLE_IMAGE_CAPTIONS=1          # caption PDF figures with BLIP (needs transformers+torch+pillow)

# --- Vector store: numpy (default, SQLite-friendly) or pgvector (Postgres) ---
# VECTOR_BACKEND=pgvector
# Requires a Postgres with the vector extension and a Postgres DATABASE_URL.
# IMPORTANT: URL-encode special chars in the password (@ -> %40), e.g. a password
# "pg24@9121" becomes "pg24%409121":
#   DATABASE_URL=postgresql+psycopg2://postgres:pg24%409121@localhost:5432/studyquest
# The app runs `CREATE EXTENSION IF NOT EXISTS vector` on startup.

# --- Langfuse tracing (optional, env-gated; no-op without keys) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
