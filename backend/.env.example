# --- Phase 1 (required to run) ---
DATABASE_URL=sqlite:///./studyquest.db
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_ORIGIN=http://localhost:3000

# --- Phase 2+: LLM via OpenRouter (OpenAI-compatible) ---
# Paste your key here. WITHOUT it the tutor runs in a deterministic mock mode.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter model slugs; override freely (e.g. openai/gpt-4o-mini, google/gemini-flash-1.5)
OPENROUTER_MODEL_FAST=anthropic/claude-3.5-haiku
OPENROUTER_MODEL_SMART=anthropic/claude-3.5-sonnet

# --- Phase 10: LangSmith tracing (optional) ---
# LANGCHAIN_API_KEY=
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=studyquest-ai
