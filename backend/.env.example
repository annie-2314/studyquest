# --- Phase 1 (required to run) ---
DATABASE_URL=sqlite:///./studyquest.db
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_ORIGIN=http://localhost:3000

# --- Phase 2+: LLM via OpenRouter (OpenAI-compatible) ---
# Paste your key here. WITHOUT it the tutor runs in a deterministic mock mode.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter model slugs. Low-cost defaults below; SMART must be vision-capable
# (used by the image solver). Override freely with any slug from openrouter.ai/models.
OPENROUTER_MODEL_FAST=meta-llama/llama-3.1-8b-instruct
OPENROUTER_MODEL_SMART=google/gemma-3-12b-it

# --- Phase 10: LangSmith tracing (optional) ---
# LANGCHAIN_API_KEY=
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=studyquest-ai
